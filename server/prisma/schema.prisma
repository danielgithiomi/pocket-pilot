generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
}

enum AccountType {
    WALLET
    BANK
    SAVINGS
    CREDIT
    CURRENT
}

enum TransactionType {
    INCOME
    EXPENSE
}

enum TransactionCategory {
    HOUSEHOLD
    GROCERIES
    TRANSPORTATION
    ENTERTAINMENT
    UTILITIES
    HEALTH
    EDUCATION
}

model Account {
    id        String      @id @default(uuid())
    type      AccountType
    name      String
    createdAt DateTime    @default(now())
    updatedAt DateTime    @updatedAt
    balance   Float       @default(0)

    // Link to user - one-to-many
    holder   User   @relation(fields: [holderId], references: [id])
    holderId String

    // Link to transaction - one-to-many
    transactions Transaction[]

    @@unique([name, holderId])
}

model User {
    id        String   @id() @default(uuid())
    name      String   @unique
    email     String   @unique
    password  String
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    // Account locking
    lastLoginAt         DateTime?
    failedLoginAttempts Int       @default(0)
    isAccountLocked     Boolean   @default(false)

    // Link to accounts - one-to-many
    accounts Account[]
}

model Transaction {
    id       String              @id() @default(uuid())
    amount   Float
    type     TransactionType
    category TransactionCategory
    date     DateTime            @default(now())

    // Link to account - one-to-many
    account   Account @relation(fields: [accountId], references: [id])
    accountId String
}
