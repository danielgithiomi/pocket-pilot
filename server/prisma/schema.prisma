generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
    // url      = env("DATABASE_URL")
}

enum AccountType {
    WALLET
    BANK
    SAVINGS
    CREDIT
    CURRENT
}

model Account {
    id        String      @id @default(uuid())
    type      AccountType
    name      String
    createdAt DateTime    @default(now())
    updatedAt DateTime    @updatedAt
    balance   Float       @default(0)

    // Link to user - one-to-many
    holder   User   @relation(fields: [holderId], references: [id], onDelete: Cascade)
    holderId String

    // Link to transaction - one-to-many
    transactions Transaction[]

    @@unique([name, holderId])
}

model User {
    id        String   @id() @default(uuid())
    name      String   @unique
    email     String   @unique
    password  String
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    // Account locking
    lastLoginAt         DateTime?
    failedLoginAttempts Int       @default(0)
    isAccountLocked     Boolean   @default(false)

    // Link to accounts - one-to-many
    accounts Account[]

    // Link to categories - one-to-many
    categories Categories[]

    // Link to preferences - one-to-one
    userPreferences UserPreferences?
}

model UserPreferences {
    id String @id @default(uuid())

    defaultCurrency      String @default("USD")
    preferredLanguage    String @default("en")
    monthlySpendingLimit Float  @default(0)

    // Link to user - one-to-one
    user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
    userId String @unique
}

enum TransactionType {
    INCOME
    EXPENSE
    TRANSFER
}

model Transaction {
    id          String          @id() @default(uuid())
    amount      Float
    type        TransactionType
    description String?
    category    String
    date        DateTime        @default(now())

    // Link to account - one-to-many
    account   Account @relation(fields: [accountId], references: [id], onDelete: Cascade)
    accountId String
}

enum CategoryType {
    INCOME
    EXPENSE
}

model Categories {
    id          String   @id @default(uuid())
    incomes     String[]
    expenses    String[]
    createdAt   DateTime @default(now())
    lastUpdated DateTime @updatedAt()

    // Link to user - one-to-many
    user   User   @relation(fields: [userId], references: [id])
    userId String @unique
}

enum GoalStatus {
    ACTIVE
    PAUSED
    FAILED
    PENDING
    COMPLETED
}

enum GoalCategory {
    LOAN
    TRAVEL
    SAVINGS
    PURCHASE
    VACATION
    EDUCATION
    RETIREMENT
    INVESTMENTS
    DEBT_PAYMENT
    EMERGENCY_FUND
    OTHER
}

model Goals {
    id     String @id @default(uuid())
    userId String

    name        String
    description String

    endDate   DateTime
    startDate DateTime

    status   GoalStatus   @default(ACTIVE)
    category GoalCategory

    monthlyContribution Float
    targetAmount        Float
    currentAmount       Float @default(0)

    updatedAt DateTime @updatedAt()
    createdAt DateTime @default(now())
}

enum BillType {
    YEARLY
    MONTHLY
    ONE_TIME
}

model Bills {
    id     String @id @default(uuid())
    userId String

    amount   Float
    name     String
    type     BillType
    currency String

    dueDate DateTime
}
